# Este proyecto usa exclusivamente pnpm.
# engine-strict hace que npm/yarn fallen por el campo "engines" de package.json.
engine-strict=true

# No auto-aprovisionar la versión de pnpm del campo "packageManager".
# En Deno Deploy ese mecanismo intentaba instalar pnpm 11.2.2 y quedaba roto
# (dist/pnpm.mjs no encontrado). Con esto, cada entorno usa su pnpm instalado.
manage-package-manager-versions=false
